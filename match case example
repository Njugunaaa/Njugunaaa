def is_weekend():
    day = input("Please enter the day of the week: ").upper()
    match day:
        case "Sunday":
            return True
        case "Monday":
            return False
        case "Tuesday":
            return False
        case "Wednesday":
            return False
        case "Thursday":
            return False
        case "Friday":
            return False
        case "Saturday":
            return True
        case _:
            return"Invalid input Please Enter a valid day of the week"

print(is_weekend())
